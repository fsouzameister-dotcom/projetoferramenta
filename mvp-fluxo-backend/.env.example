# Copie para .env e preencha (não commite .env com segredos reais)

NODE_ENV=development

PORT=3000

JWT_SECRET=gere_um_segredo_longo_e_unico

PG_HOST=localhost
PG_PORT=5432
PG_USER=mvp_user
