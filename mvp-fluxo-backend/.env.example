# Copie para .env e preencha (não commite .env com segredos reais)

NODE_ENV=development

PORT=3000

JWT_SECRET=gere_um_segredo_longo_e_unico

PG_HOST=localhost
PG_PORT=5432
PG_USER=mvp_user
PG_PASSWORD=sua_senha
PG_DATABASE=mvp_core

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Opcional em desenvolvimento: se omitido, o backend aceita localhost/127.0.0.1 em qualquer porta
# (útil quando o Vite usa 5174 porque 5173 está ocupada). Defina uma origem fixa se preferir:
# CORS_ORIGIN=http://localhost:5174

# Em produção, CORS_ORIGIN é obrigatória (definida em config.ts)

# Login só com email/senha em desenvolvimento (após: npm run seed:dev)
# Deve ser o mesmo UUID do tenant criado pelo seed (ou o seu tenant real).
DEFAULT_LOGIN_TENANT_ID=00000000-0000-4000-8000-000000000001

# ── WhatsApp Cloud API (Fase 1 — Opção B: credenciais por tenant via API admin) ──
# Webhook público: GET/POST /webhooks/whatsapp (configure na Meta com a URL pública do backend)
# Opcional se você salvar no painel Admin → WhatsApp → "Configuração global" (valores no banco têm prioridade):
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=defina_um_token_unico_e_use_o_mesmo_no_app_meta
# WHATSAPP_APP_SECRET=app_secret_do_app_meta_para_validar_x_hub_signature_256
# Opcional: WHATSAPP_GRAPH_API_VERSION=v21.0
# Apenas desenvolvimento local (ex.: sem assinatura): WHATSAPP_SKIP_SIGNATURE_VERIFY=true
#
# Webhooks Twilio (POST form): /webhooks/twilio/messages e /webhooks/twilio/status
# Apenas desenvolvimento: TWILIO_SKIP_SIGNATURE_VERIFY=true

# Credenciais usadas por npm run seed:dev (opcional)
# SEED_ADMIN_EMAIL=admin@local.dev
# SEED_ADMIN_PASSWORD=AdminDev123!
# SEED_ADMIN_NAME=Administrador (dev)
